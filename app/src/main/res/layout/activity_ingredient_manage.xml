<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgApp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="食材与采购管理"
            android:textColor="@color/textPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_surface"
            android:padding="12dp"
            android:textColor="@color/textPrimary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="新增采购记录"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPurchaseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:hint="食材名称"
            android:padding="10dp" />

        <EditText
            android:id="@+id/etPurchaseQty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:hint="数量"
            android:inputType="numberDecimal"
            android:padding="10dp" />

        <EditText
            android:id="@+id/etPurchasePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:hint="价格"
            android:inputType="numberDecimal"
            android:padding="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSavePurchase"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="保存采购记录"
            app:backgroundTint="@color/accent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="家庭库存管理"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etInventoryName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:hint="食材名称"
            android:padding="10dp" />

        <EditText
            android:id="@+id/etInventoryQty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:hint="库存数量"
            android:inputType="numberDecimal"
            android:padding="10dp" />

        <EditText
            android:id="@+id/etLowThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:hint="库存预警阈值"
            android:inputType="numberDecimal"
            android:padding="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveInventory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="保存库存记录"
            app:backgroundTint="@color/accent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="最近采购"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPurchaseList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:padding="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="库存清单"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInventoryList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>

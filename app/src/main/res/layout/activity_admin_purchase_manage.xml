<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgApp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="采购记录管理" android:textSize="24sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvPurchaseStats" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnExportPurchaseCsv" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="导出CSV到剪贴板" app:backgroundTint="@color/accent"/>
        <TextView android:id="@+id/tvPurchaseRecords" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
    </LinearLayout>
</ScrollView>

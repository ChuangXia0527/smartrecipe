<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgApp"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- =================== HOME =================== -->
        <LinearLayout
            android:id="@+id/sectionHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="20dp"
            android:paddingRight="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="发现美食 🔎"
                android:textColor="@color/textPrimary"
                android:textSize="34sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_search_shell"
                android:gravity="center_vertical"
                android:paddingLeft="14dp"
                android:paddingRight="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/textMuted" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="搜索食谱、食材..."
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textMuted" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSearch"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:minWidth="44dp"
                    android:minHeight="44dp"
                    android:text=""
                    app:icon="@android:drawable/ic_menu_search"
                    app:iconTint="@color/textSecondary"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="12dp"
                    app:strokeColor="#13000000"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipRecommend"
                        style="@style/Widget.SmartRecipe.CategoryChip.Active"
                        android:text="推荐" />

                    <TextView
                        android:id="@+id/chipBreakfast"
                        style="@style/Widget.SmartRecipe.CategoryChip"
                        android:text="早餐" />

                    <TextView
                        android:id="@+id/chipLunch"
                        style="@style/Widget.SmartRecipe.CategoryChip"
                        android:text="午餐" />

                    <TextView
                        android:id="@+id/chipDinner"
                        style="@style/Widget.SmartRecipe.CategoryChip"
                        android:text="晚餐" />

                    <TextView
                        android:id="@+id/chipDessert"
                        style="@style/Widget.SmartRecipe.CategoryChip"
                        android:text="甜点" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="推荐食谱"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="6dp"
                android:text="暂无结果，可尝试更换关键词"
                android:textColor="@color/textSecondary"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecipes"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="12dp" />
        </LinearLayout>

        <!-- =================== FEATURE =================== -->
        <ScrollView
            android:id="@+id/sectionFeature"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="智能助手 🤖"
                    android:textColor="@color/textPrimary"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="AI 赋能，让烹饪不仅仅是烹饪"
                    android:textColor="@color/textSecondary"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRecognize"
                        android:layout_width="0dp"
                        android:layout_height="180dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="拍照识别&#10;识别食材生成食谱"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        app:backgroundTint="@color/accent"
                        app:cornerRadius="20dp"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconGravity="textTop"
                        app:iconPadding="20dp"
                        app:iconTint="@android:color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVoice"
                        android:layout_width="0dp"
                        android:layout_height="180dp"
                        android:layout_marginLeft="12dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="语音助手&#10;语音控制烹饪步骤"
                        android:textAllCaps="false"
                        android:textColor="@color/textPrimary"
                        android:textSize="16sp"
                        app:backgroundTint="@android:color/white"
                        app:cornerRadius="20dp"
                        app:elevation="2dp"
                        app:icon="@android:drawable/ic_btn_speak_now"
                        app:iconGravity="textTop"
                        app:iconPadding="20dp"
                        app:iconTint="#3B82F6"
                        app:strokeColor="#12000000"
                        app:strokeWidth="1dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="实用工具"
                    android:textColor="@color/textSecondary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- ✅ 修复：原来这里多了一行孤立的 android:text -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIngredientFilter"
                    style="@style/Widget.SmartRecipe.FeatureRowButton"
                    android:layout_marginTop="10dp"
                    android:text="食材筛选\n快速筛选所需食材" />


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPreference"
                    style="@style/Widget.SmartRecipe.FeatureRowButton"
                    android:layout_marginTop="12dp"
                    android:text="智能筛选\n基于口味、时间、卡路里" />
            </LinearLayout>
        </ScrollView>

        <!-- =================== MINE =================== -->
        <ScrollView
            android:id="@+id/sectionMine"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="26dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="74dp"
                                android:layout_height="74dp"
                                android:background="@drawable/bg_avatar"
                                android:padding="16dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="@android:color/white" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvMineTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="美食家小王"
                                    android:textColor="@color/textPrimary"
                                    android:textSize="30sp"
                                    android:textStyle="bold" />

                            </LinearLayout>
                        </LinearLayout>



                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="常用功能"
                    android:textColor="@color/textSecondary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProfile"
                    style="@style/Widget.SmartRecipe.MineRowButton"
                    android:layout_marginTop="10dp"
                    android:text="我的信息（个人资料）" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavorite"
                    style="@style/Widget.SmartRecipe.MineRowButton"
                    android:layout_marginTop="10dp"
                    android:text="我的收藏" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistory"
                    style="@style/Widget.SmartRecipe.MineRowButton"
                    android:layout_marginTop="10dp"
                    android:text="浏览历史" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    style="@style/Widget.SmartRecipe.MineRowButton"
                    android:layout_marginTop="10dp"
                    android:text="退出登录"
                    android:textColor="#B91C1C"
                    app:icon="@android:drawable/ic_lock_power_off"
                    app:iconTint="#B91C1C" />

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:itemActiveIndicatorStyle="@style/Widget.SmartRecipe.BottomNavActiveIndicator"
        app:itemIconSize="26dp"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
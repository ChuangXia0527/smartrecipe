<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgApp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="互动反馈"
            android:textColor="@color/textPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAnnouncement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_surface"
            android:padding="12dp" />

        <EditText
            android:id="@+id/etFeedbackType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_surface"
            android:hint="反馈类型（功能建议/问题投诉）"
            android:padding="10dp" />

        <EditText
            android:id="@+id/etFeedbackContent"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:gravity="top"
            android:hint="请输入反馈内容"
            android:padding="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitFeedback"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="提交反馈"
            app:backgroundTint="@color/accent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="我的反馈与回复"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFeedbackList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_surface"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>

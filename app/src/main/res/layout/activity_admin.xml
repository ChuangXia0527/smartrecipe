<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgApp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="系统后台管理"
            android:textColor="@color/textPrimary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="选择模块进入详细管理"
            android:textColor="@color/textSecondary"
            android:textSize="18sp" />

        <!-- 模块按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModuleUser"
            style="@style/Widget.SmartRecipe.MineRowButton"
            android:layout_marginTop="14dp"
            android:text="用户管理" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModuleRecipe"
            style="@style/Widget.SmartRecipe.MineRowButton"
            android:layout_marginTop="10dp"
            android:text="食谱与食材管理" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModulePurchase"
            style="@style/Widget.SmartRecipe.MineRowButton"
            android:layout_marginTop="10dp"
            android:text="采购记录管理" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModuleAi"
            style="@style/Widget.SmartRecipe.MineRowButton"
            android:layout_marginTop="10dp"
            android:text="Android与AI技术配置" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModuleSystem"
            style="@style/Widget.SmartRecipe.MineRowButton"
            android:layout_marginTop="10dp"
            android:text="系统管理" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModuleProfile"
            style="@style/Widget.SmartRecipe.MineRowButton"
            android:layout_marginTop="10dp"
            android:text="个人信息管理" />

        <!-- 顶部退出管理员登录按钮（保留带图标版本） -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminLogout"
            style="@style/Widget.SmartRecipe.MineRowButton"
            android:layout_marginTop="10dp"
            android:text="退出管理员登录"
            android:textColor="#B91C1C"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconTint="#B91C1C" />

        <!-- 系统管理员控制台 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="系统管理员控制台"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- 1) 用户管理 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="1) 用户管理"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAdminUsers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_surface"
            android:padding="10dp" />

        <EditText
            android:id="@+id/etAdminUserId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="用户ID"
            android:inputType="number"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_surface"
            android:padding="10dp"/>

        <EditText
            android:id="@+id/etAdminResetPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="重置密码"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_surface"
            android:padding="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminDisableUser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="禁用"
                app:backgroundTint="@color/accent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminEnableUser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="启用"
                app:backgroundTint="@color/accent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminResetPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="重置密码"
                app:backgroundTint="@color/accent"/>
        </LinearLayout>

        <!-- 2) 食谱/分类/食材管理 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="2) 食谱/分类/食材管理"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAdminRecipeSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_surface"
            android:padding="10dp"/>

        <!-- 食谱相关 EditText 和操作按钮 -->
        <!-- 保持原有 ID，未修改 -->
        <!-- ...后续代码保持不变，直到最后... -->

    </LinearLayout>
</ScrollView>
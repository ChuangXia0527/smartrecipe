<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgApp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="偏好设置"
            android:textColor="@color/textPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="完善偏好后，推荐会更懂你"
            android:textColor="@color/textSecondary" />

        <EditText
            android:id="@+id/etTaste"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_surface"
            android:hint="口味偏好（辣 / 清淡）"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textSecondary" />

        <EditText
            android:id="@+id/etAllergies"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_surface"
            android:hint="忌口/过敏源（逗号分隔）"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textSecondary" />

        <EditText
            android:id="@+id/etDiet"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_surface"
            android:hint="饮食类型（减脂 / 增肌 / 素食）"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textSecondary" />

        <EditText
            android:id="@+id/etCommonIngredients"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_surface"
            android:hint="常用食材（逗号分隔）"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textSecondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSavePreference"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="保存"
            app:backgroundTint="@color/accent"
            app:cornerRadius="14dp" />

    </LinearLayout>
</ScrollView>

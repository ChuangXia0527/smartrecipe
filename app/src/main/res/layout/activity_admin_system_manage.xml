<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgApp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="系统管理" android:textSize="24sp" android:textStyle="bold"/>
        <EditText android:id="@+id/etAnnouncementTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="公告标题" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
        <EditText android:id="@+id/etAnnouncementContent" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="公告内容" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnPublishAnnouncement" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="发布公告" app:backgroundTint="@color/accent"/>
        <TextView android:id="@+id/tvAnnouncements" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_input_surface" android:padding="10dp"/>

        <EditText android:id="@+id/etFeedbackId" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="反馈ID" android:inputType="number" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
        <EditText android:id="@+id/etFeedbackStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="处理状态" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
        <EditText android:id="@+id/etFeedbackReply" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="处理回复" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnProcessFeedback" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="处理反馈" app:backgroundTint="@color/accent"/>
        <TextView android:id="@+id/tvFeedbacks" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_input_surface" android:padding="10dp"/>

        <EditText android:id="@+id/etConfigKey" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="系统配置Key" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
        <EditText android:id="@+id/etConfigValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="系统配置Value" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveSystemConfig" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="保存系统配置" app:backgroundTint="@color/accent"/>
        <TextView android:id="@+id/tvSystemConfig" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_input_surface" android:padding="10dp"/>
    </LinearLayout>
</ScrollView>

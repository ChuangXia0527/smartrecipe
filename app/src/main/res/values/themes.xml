<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Smartrecipe" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.Smartrecipe" parent="Base.Theme.Smartrecipe" />

    <style name="Widget.SmartRecipe.FeatureButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">#FFFFFFFF</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">#1E94A3B8</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.SmartRecipe.FeatureRowButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="backgroundTint">#FFFFFFFF</item>
        <item name="strokeColor">#12000000</item>
        <item name="strokeWidth">1dp</item>
        <item name="icon">@android:drawable/ic_media_next</item>
        <item name="iconGravity">end</item>
        <item name="iconTint">@color/textMuted</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.SmartRecipe.MineRowButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">62dp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="backgroundTint">#FFFFFFFF</item>
        <item name="cornerRadius">16dp</item>
        <item name="strokeColor">#10000000</item>
        <item name="strokeWidth">1dp</item>
        <item name="icon">@android:drawable/ic_menu_more</item>
        <item name="iconGravity">end</item>
        <item name="iconTint">@color/textMuted</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.SmartRecipe.CategoryChip" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/bg_category_chip</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.SmartRecipe.CategoryChip.Active" parent="Widget.SmartRecipe.CategoryChip">
        <item name="android:background">@drawable/bg_category_chip_active</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="Widget.SmartRecipe.StatItem" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="Widget.SmartRecipe.BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#FFF3E8</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Material3.Corner.ExtraLarge</item>
    </style>
</resources>
